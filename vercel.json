{
  "cleanUrls": true,
  "public": false,
  "experimentalServices": {
    "frontend": {
      "name": "The Eye Doctors - Frontend",
      "buildCommand": "npm run build",
      "installCommand": "npm install",
      "outputDirectory": "frontend/dist",
      "framework": "vite",
      "entrypoint": "frontend"
    },
    "backend": {
      "name": "The Eye Doctors - Backend",
      "buildCommand": "npm run build",
      "installCommand": "npm install",
      "entrypoint": "backend",
      "serverless": true
    }
  }
}
